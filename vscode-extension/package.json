{
  "name": "spring-boot-debugger",
  "displayName": "Spring Boot Debugger",
  "description": "Watches Spring Boot run, test, and build output and explains errors in plain language. One sentence names the problem, one gives the fix.",
  "version": "0.10.0",
  "publisher": "okapiorbits",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jehadbaeth/spring-debugger"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Linters",
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "springDebugger.diagnosePasted",
        "title": "Diagnose Pasted Output",
        "category": "Spring Boot Debugger"
      },
      {
        "command": "springDebugger.openCard",
        "title": "Open Diagnosis Card",
        "category": "Spring Boot Debugger"
      },
      {
        "command": "springDebugger.clearHistory",
        "title": "Clear History",
        "category": "Spring Boot Debugger",
        "icon": "$(clear-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "springDebugger",
          "title": "Spring Boot Debugger",
          "icon": "media/leaf.svg"
        }
      ]
    },
    "views": {
      "springDebugger": [
        {
          "id": "springDebuggerHistory",
          "name": "Diagnosis History"
        }
      ]
    },
    "configuration": {
      "title": "Spring Boot Debugger",
      "properties": {
        "springDebugger.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Spring Boot Debugger. When off, no output is watched or diagnosed."
        },
        "springDebugger.minimumConfidence": {
          "type": "string",
          "enum": ["HIGH", "MEDIUM", "LOW"],
          "default": "MEDIUM",
          "description": "Only surface diagnoses at or above this confidence."
        },
        "springDebugger.maxHistory": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "Maximum number of diagnoses kept in the history view."
        },
        "springDebugger.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification for the first error of a burst."
        },
        "springDebugger.watchTestResults": {
          "type": "boolean",
          "default": true,
          "description": "Watch JUnit result files (Gradle build/test-results, Maven surefire-reports)."
        },
        "springDebugger.watchLogFile": {
          "type": "boolean",
          "default": true,
          "description": "Tail Spring Boot log files discovered from logging.file.name."
        },
        "springDebugger.logFilePath": {
          "type": "string",
          "default": "",
          "description": "Explicit log file to tail. Leave empty to auto-discover every logging.file.name in the workspace."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "springDebugger.clearHistory",
          "when": "view == springDebuggerHistory",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "springDebugger.openCard",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "copy-assets": "node scripts/copy-assets.js",
    "compile": "tsc -p ./",
    "bundle": "npm run copy-assets && node esbuild.js",
    "test": "npm run copy-assets && vitest run",
    "test:watch": "vitest",
    "package": "npm run bundle && vsce package --no-dependencies"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
