<idea-plugin>
    <id>com.springdebugger</id>
    <name>Spring Boot Debugger</name>
    <vendor email="" url="">Spring Debugger Contributors</vendor>
    <description><![CDATA[
        Monitors run, test, and build output for Spring Boot errors.
        When an error is detected it surfaces a one-sentence diagnosis and one-sentence fix,
        eliminating the need to read cascading stack traces.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">

        <applicationService
            serviceImplementation="com.springdebugger.SpringDebuggerService"/>

        <applicationService
            serviceImplementation="com.springdebugger.settings.SpringDebuggerSettings"/>

        <projectService
            serviceImplementation="com.springdebugger.service.DiagnosisHistoryService"/>

        <projectService
            serviceImplementation="com.springdebugger.terminal.TerminalMonitorService"/>

        <projectService
            serviceImplementation="com.springdebugger.service.TestResultsWatchService"/>

        <projectService
            serviceImplementation="com.springdebugger.service.LogFileTailService"/>

        <applicationConfigurable
            parentId="tools"
            id="com.springdebugger.settings"
            displayName="Spring Boot Debugger"
            instance="com.springdebugger.settings.SpringDebuggerSettingsConfigurable"/>

        <postStartupActivity
            implementation="com.springdebugger.SpringDebuggerStartupActivity"/>

        <!-- M6: build taps. Internal JPS compiler runs BuildOutputTap after compilation;
             delegated Gradle/Maven builds stream through ExternalBuildOutputTap. -->
        <compiler.task
            execute="AFTER"
            implementation="com.springdebugger.tap.BuildOutputTap"/>

        <externalSystemTaskNotificationListener
            implementation="com.springdebugger.tap.ExternalBuildOutputTap"/>

        <toolWindow
            id="Spring Debugger"
            anchor="bottom"
            factoryClass="com.springdebugger.ui.SpringDebuggerToolWindowFactory"
            canCloseContents="false"/>

        <notificationGroup
            id="Spring Debugger"
            displayType="BALLOON"
            isLogByDefault="true"/>

        <!-- Treat .robot as plain text so convention checks can inspect it even with no dedicated
             Robot Framework plugin installed. Secondary association: yields to such a plugin. -->
        <fileType
            name="Robot Framework (Spring Boot Debugger)"
            implementationClass="com.springdebugger.convention.robot.RobotFileType"
            fieldName="INSTANCE"
            extensions="robot"/>

        <!-- Code convention validation: a single catalog-driven inspection. Runs on the fly as you
             type, in batch via Analyze > Inspect Code, and at commit time. Rule on/off lives in
             conventions.yaml and the plugin settings, not the inspection profile. The same
             implementation is registered for Java and for plain text (which covers .robot); each
             rule self-filters by file type via its appliesTo. -->
        <localInspection
            language="JAVA"
            shortName="SpringDebuggerConventionsJava"
            displayName="Team code conventions (Java)"
            groupName="Spring Boot Debugger"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="com.springdebugger.convention.ConventionInspection"/>

        <localInspection
            language="TEXT"
            shortName="SpringDebuggerConventionsText"
            displayName="Team code conventions (Robot/text)"
            groupName="Spring Boot Debugger"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="com.springdebugger.convention.ConventionInspection"/>

    </extensions>
</idea-plugin>
