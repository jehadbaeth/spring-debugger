<idea-plugin>
    <id>com.springdebugger</id>
    <name>Spring Boot Debugger</name>
    <vendor email="" url="">Spring Debugger Contributors</vendor>
    <description><![CDATA[
        Monitors run, test, and build output for Spring Boot errors.
        When an error is detected it surfaces a one-sentence diagnosis and one-sentence fix,
        eliminating the need to read cascading stack traces.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">

        <applicationService
            serviceImplementation="com.springdebugger.SpringDebuggerService"/>

        <applicationService
            serviceImplementation="com.springdebugger.settings.SpringDebuggerSettings"/>

        <projectService
            serviceImplementation="com.springdebugger.service.DiagnosisHistoryService"/>

        <projectService
            serviceImplementation="com.springdebugger.terminal.TerminalMonitorService"/>

        <applicationConfigurable
            parentId="tools"
            id="com.springdebugger.settings"
            displayName="Spring Boot Debugger"
            instance="com.springdebugger.settings.SpringDebuggerSettingsConfigurable"/>

        <postStartupActivity
            implementation="com.springdebugger.SpringDebuggerStartupActivity"/>

        <!-- M6: build taps. Internal JPS compiler runs BuildOutputTap after compilation;
             delegated Gradle/Maven builds stream through ExternalBuildOutputTap. -->
        <compiler.task
            execute="AFTER"
            implementation="com.springdebugger.tap.BuildOutputTap"/>

        <externalSystemTaskNotificationListener
            implementation="com.springdebugger.tap.ExternalBuildOutputTap"/>

        <toolWindow
            id="Spring Debugger"
            anchor="bottom"
            factoryClass="com.springdebugger.ui.SpringDebuggerToolWindowFactory"
            canCloseContents="false"/>

        <notificationGroup
            id="Spring Debugger"
            displayType="BALLOON"
            isLogByDefault="true"/>

    </extensions>
</idea-plugin>
